-- composeApp/src/commonMain/sqldelight/com/dailychallenge/db/Challenge.sq

CREATE TABLE ChallengeEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    streakCount INTEGER NOT NULL DEFAULT 0,
    lastCompletionDate INTEGER NOT NULL DEFAULT 0
);

-- Queries generated by SQLDelight:

getChallenge:
SELECT * FROM ChallengeEntity LIMIT 1;

insertOrUpdate:
INSERT OR REPLACE INTO ChallengeEntity (id, streakCount, lastCompletionDate)
VALUES (1, ?, ?);